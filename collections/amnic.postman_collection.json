    "_postman_id": "66cf1ac6-965d-4864-9987-9123ebd5a318",
    "name": "Amnic Cloud Cost Observability API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Amnic API provides programmatic access to cloud cost data, enabling automation of reporting and integration with other tools. Use this API to retrieve saved chart data with custom filters for AWS, GCP, Azure, and Kubernetes cost analytics.\n\nContact Support:\n Name: Amnic Support",
